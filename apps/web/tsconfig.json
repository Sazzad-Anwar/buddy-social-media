{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/types": ["../../packages/types/src"],
    },
    "plugins": [
      {
        "name": "next",
      },
    ],
    "strictNullChecks": true,
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts",
  ],
  "exclude": ["node_modules"],
}
